# ─── App ──────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
APP_NAME=NEXUS
APP_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000

# ─── JWT ──────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_random_64_char_string
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_to_a_different_random_64_char_string
JWT_REFRESH_EXPIRES_IN=7d

# ─── MongoDB ──────────────────────────────────────────────────
MONGO_ROOT_USER=nexus
MONGO_ROOT_PASSWORD=change_me
MONGODB_URI=mongodb://nexus:change_me@localhost:27017/nexus?authSource=admin

# ─── Redis ────────────────────────────────────────────────────
REDIS_PASSWORD=change_me
REDIS_URL=redis://:change_me@localhost:6379

# ─── Qdrant (Vector DB) ───────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=nexus_embeddings

# ─── AI / LLM ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
LLM_MODEL=claude-sonnet-4-6
EMBEDDING_MODEL=text-embedding-3-small
LLM_MAX_TOKENS=2000
LLM_TEMPERATURE=0.1

# ─── Integrations ─────────────────────────────────────────────
# Salesforce
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
SALESFORCE_REDIRECT_URI=http://localhost:3001/api/v1/integrations/salesforce/callback
SALESFORCE_INSTANCE_URL=

# Jira
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=NEXUS

# Slack
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_APP_TOKEN=

# Zendesk
ZENDESK_SUBDOMAIN=
ZENDESK_EMAIL=
ZENDESK_API_TOKEN=

# HubSpot
HUBSPOT_ACCESS_TOKEN=
HUBSPOT_PORTAL_ID=

# Notion
NOTION_API_KEY=
NOTION_DATABASE_ID=

# Google Sheets
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_SPREADSHEET_ID=

# ─── Encryption ───────────────────────────────────────────────
ENCRYPTION_KEY=change_me_32_char_encryption_key

# ─── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
AI_RATE_LIMIT_MAX=20

# ─── File Upload ──────────────────────────────────────────────
UPLOAD_MAX_SIZE_MB=50
UPLOAD_DIR=./uploads

# ─── Observability ────────────────────────────────────────────
OTEL_SERVICE_NAME=nexus-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
LOG_LEVEL=debug
SENTRY_DSN=

# ─── Grafana ──────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=change_me

# ─── Next.js (Frontend) ───────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001
NEXT_PUBLIC_APP_NAME=NEXUS
